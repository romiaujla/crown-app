#!/usr/bin/env sh

# ──────────────────────────────────────────────────────────────
# Pre-commit hook — auto-formats, then runs typecheck and tests.
# Blocks the commit if formatting command, typecheck, or tests fail.
# Skip with: HUSKY=0 git commit  (use sparingly)
# ──────────────────────────────────────────────────────────────

FAILED_CHECKS=""

echo ""
echo "🔍  Running pre-commit checks…"
echo ""

# ── 1. Prettier ──────────────────────────────────────────────
echo "▸ prettier (auto-format)"
STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"
if [ -n "$STAGED_FILES" ]; then
  pnpm exec prettier --write --ignore-unknown $STAGED_FILES --log-level warn
  if [ $? -ne 0 ]; then
    FAILED_CHECKS="$FAILED_CHECKS prettier"
    echo "✖  prettier — FAILED"
  else
    # Re-stage only files that were staged before formatting.
    git add $STAGED_FILES
    echo "✔  prettier — passed"
  fi
else
  echo "✔  prettier — skipped (no staged files)"
fi
echo ""

# ── 2. Typecheck ─────────────────────────────────────────────
echo "▸ typecheck"
pnpm typecheck
if [ $? -ne 0 ]; then
  FAILED_CHECKS="$FAILED_CHECKS typecheck"
  echo "✖  typecheck — FAILED"
else
  echo "✔  typecheck — passed"
fi
echo ""

# ── 3. Tests ─────────────────────────────────────────────────
echo "▸ tests"
pnpm test
if [ $? -ne 0 ]; then
  FAILED_CHECKS="$FAILED_CHECKS tests"
  echo "✖  tests — FAILED"
else
  echo "✔  tests — passed"
fi
echo ""

# ── Summary ──────────────────────────────────────────────────
if [ -n "$FAILED_CHECKS" ]; then
  echo "══════════════════════════════════════════════════════"
  echo "  Commit blocked. Failed checks:$FAILED_CHECKS"
  echo "══════════════════════════════════════════════════════"
  echo ""
  echo "Fix the issues above, then try committing again."
  echo "To skip pre-commit checks (emergency only): HUSKY=0 git commit"
  echo ""
  exit 1
fi

echo "✔  All pre-commit checks passed."
echo ""
