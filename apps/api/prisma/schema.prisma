generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformUserAccountStatus {
  active
  disabled
  inactive
}

enum TenantStatus {
  active
  hard_deprovisioned
  inactive
  provisioning
  provisioning_failed
}

enum ManagementSystemTypeAvailabilityStatusEnum {
  active
  inactive
}

enum PlatformRoleCodeEnum {
  super_admin
}

enum TenantRoleCodeEnum {
  tenant_admin
  tenant_user
}

enum RoleAssignmentStatusEnum {
  active
  inactive
}

enum TenantMembershipStatusEnum {
  active
  inactive
}

model User {
  id            String                    @id @default(cuid())
  email         String                    @unique
  username      String?                   @unique
  passwordHash  String?                   @map("password_hash")
  accountStatus PlatformUserAccountStatus @default(active) @map("account_status")
  displayName   String                    @map("display_name")
  role          String?
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  tenantMemberships      TenantMembership[]
  platformRoleAssignments UserPlatformRoleAssignment[]

  @@map("users")
}

model Tenant {
  id         String       @id @default(cuid())
  name       String
  slug       String       @unique
  schemaName String       @unique @map("schema_name")
  status     TenantStatus @default(active)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  tenantMemberships TenantMembership[]
  versions          TenantSchemaVersion[]

  @@map("tenants")
}

model PlatformRole {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleCode    PlatformRoleCodeEnum @unique @map("role_code")
  displayName String               @map("display_name")
  description String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  userAssignments UserPlatformRoleAssignment[]

  @@map("platform_roles")
}

model UserPlatformRoleAssignment {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String                   @map("user_id")
  platformRoleId   String                   @map("platform_role_id") @db.Uuid
  assignmentStatus RoleAssignmentStatusEnum @default(active) @map("assignment_status")
  assignedAt       DateTime                 @default(now()) @map("assigned_at")
  endedAt          DateTime?                @map("ended_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformRole PlatformRole @relation(fields: [platformRoleId], references: [id], onDelete: Cascade)

  @@unique([userId, platformRoleId])
  @@map("user_platform_role_assignments")
}

model ManagementSystemType {
  id                 String                                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  typeCode           String                                     @map("type_code")
  version            String                                     @default("1.0")
  displayName        String                                     @map("display_name")
  description        String?
  availabilityStatus ManagementSystemTypeAvailabilityStatusEnum @default(active) @map("availability_status")
  createdAt          DateTime                                   @default(now()) @map("created_at")
  updatedAt          DateTime                                   @updatedAt @map("updated_at")

  roles ManagementSystemTypeRole[]

  @@unique([typeCode, version])
  @@map("management_system_types")
}

model TenantRole {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleCode    TenantRoleCodeEnum @unique @map("role_code")
  displayName String             @map("display_name")
  description String?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  membershipAssignments TenantMembershipRoleAssignment[]

  @@map("tenant_roles")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleCode    String   @unique @map("role_code")
  displayName String   @map("display_name")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  managementSystemTypes ManagementSystemTypeRole[]

  @@map("roles")
}

model ManagementSystemTypeRole {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  managementSystemTypeId String   @map("management_system_type_id") @db.Uuid
  roleId                 String   @map("role_id") @db.Uuid
  isDefault              Boolean  @default(false) @map("is_default")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  managementSystemType ManagementSystemType @relation(fields: [managementSystemTypeId], references: [id], onDelete: Cascade)
  role                 Role                 @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([managementSystemTypeId, roleId])
  @@map("management_system_type_roles")
}

model TenantMembership {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  tenantId       String   @map("tenant_id")
  membershipStatus TenantMembershipStatusEnum @default(active) @map("membership_status")
  joinedAt        DateTime @default(now()) @map("joined_at")
  endedAt         DateTime? @map("ended_at")
  role            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleAssignments TenantMembershipRoleAssignment[]

  @@unique([userId, tenantId])
  @@map("tenant_memberships")
}

model TenantMembershipRoleAssignment {
  id                 String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantMembershipId String                   @map("tenant_membership_id")
  tenantRoleId       String                   @map("tenant_role_id") @db.Uuid
  assignmentStatus   RoleAssignmentStatusEnum @default(active) @map("assignment_status")
  isPrimary          Boolean                  @default(false) @map("is_primary")
  assignedAt         DateTime                 @default(now()) @map("assigned_at")
  endedAt            DateTime?                @map("ended_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  tenantMembership TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  tenantRole       TenantRole       @relation(fields: [tenantRoleId], references: [id], onDelete: Cascade)

  @@unique([tenantMembershipId, tenantRoleId])
  @@map("tenant_membership_role_assignments")
}

model TenantSchemaVersion {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  version     String
  appliedAt   DateTime @default(now()) @map("applied_at")
  appliedBy   String   @map("applied_by")
  description String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, version])
  @@map("tenant_schema_versions")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  tenantId    String?  @map("tenant_id")
  action      String
  resource    String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
