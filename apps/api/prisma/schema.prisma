generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformUserAccountStatus {
  active
  disabled
  inactive
}

enum TenantStatus {
  active
  hard_deprovisioned
  inactive
  provisioning
  provisioning_failed
}

enum ManagementSystemTypeAvailabilityStatusEnum {
  active
  inactive
}

enum ManagementSystemRoleTemplateBootstrapRoleEnum {
  none
  tenant_admin
}

model PlatformUser {
  id            String                    @id @default(cuid())
  email         String                    @unique
  username      String?                   @unique
  passwordHash  String?                   @map("password_hash")
  accountStatus PlatformUserAccountStatus @default(active) @map("account_status")
  displayName   String                    @map("display_name")
  role          String
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  tenantLinks PlatformUserTenant[]

  @@map("platform_users")
}

model Tenant {
  id         String       @id @default(cuid())
  name       String
  slug       String       @unique
  schemaName String       @unique @map("schema_name")
  status     TenantStatus @default(active)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  platformUserTenants PlatformUserTenant[]
  versions            TenantSchemaVersion[]

  @@map("tenants")
}

model ManagementSystemType {
  id                 String                                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  typeCode           String                                     @unique @map("type_code")
  displayName        String                                     @map("display_name")
  description        String?
  availabilityStatus ManagementSystemTypeAvailabilityStatusEnum @default(active) @map("availability_status")
  createdAt          DateTime                                   @default(now()) @map("created_at")
  updatedAt          DateTime                                   @updatedAt @map("updated_at")

  roleTemplates ManagementSystemRoleTemplate[]

  @@map("management_system_types")
}

model ManagementSystemRoleTemplate {
  id                     String                                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  managementSystemTypeId String                                        @map("management_system_type_id") @db.Uuid
  roleCode               String                                        @map("role_code")
  displayName            String                                        @map("display_name")
  description            String?
  isRequired             Boolean                                       @default(false) @map("is_required")
  bootstrapRole          ManagementSystemRoleTemplateBootstrapRoleEnum @default(none) @map("bootstrap_role")
  createdAt              DateTime                                      @default(now()) @map("created_at")
  updatedAt              DateTime                                      @updatedAt @map("updated_at")

  managementSystemType ManagementSystemType @relation(fields: [managementSystemTypeId], references: [id], onDelete: Cascade)

  @@unique([managementSystemTypeId, roleCode])
  @@map("management_system_role_templates")
}

model PlatformUserTenant {
  id             String   @id @default(cuid())
  platformUserId String   @map("platform_user_id")
  tenantId       String   @map("tenant_id")
  role           String
  createdAt      DateTime @default(now()) @map("created_at")

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([platformUserId, tenantId])
  @@map("platform_user_tenants")
}

model TenantSchemaVersion {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  version     String
  appliedAt   DateTime @default(now()) @map("applied_at")
  appliedBy   String   @map("applied_by")
  description String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, version])
  @@map("tenant_schema_versions")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  tenantId    String?  @map("tenant_id")
  action      String
  resource    String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
